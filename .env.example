# Local runtime
PORT=3000
APP_ENV=development
DATABASE_URL=./data/app.db

# Feishu phase-one credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_EVENT_MODE=long_connection
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Feishu native delivery surface
FEISHU_BOT_CHAT_ID=
FEISHU_BOT_RECEIVE_ID_TYPE=chat_id
FEISHU_BASE_ENABLED=true
FEISHU_BASE_APP_TOKEN=
FEISHU_BASE_MEMBERS_TABLE=
FEISHU_BASE_RAW_EVENTS_TABLE=
FEISHU_BASE_SCORES_TABLE=
FEISHU_BASE_WARNINGS_TABLE=
FEISHU_BASE_SNAPSHOTS_TABLE=
FEISHU_BASE_QUIZ_TABLE=
FEISHU_LEARNER_HOME_DOC_TOKEN=
FEISHU_LEARNER_HOME_URL=
FEISHU_OPERATOR_HOME_DOC_TOKEN=
FEISHU_OPERATOR_HOME_URL=
FEISHU_LEADERBOARD_URL=

# --- ChatBot AI 助教（奇点小助）---
# 启用 @Bot 问答功能（默认 false，开启设为 true）
FEISHU_CHAT_BOT_ENABLED=false
# Bot 自身的 open_id（用于识别 @Bot 消息），从飞书开放平台应用详情获取
FEISHU_BOT_OPEN_ID=

# --- 语义评分（替代关键词白名单）---
# 开启后使用 LLM 语义理解替代关键词白名单进行评分
# 关闭时使用旧关键词分类器（向后兼容）
FEISHU_SEMANTIC_SCORING_ENABLED=true

# --- 主动夸赞 Bot ---
# 开启后 Bot 会主动在群里夸赞精彩回答（默认 false，仅被动回复）
FEISHU_PROACTIVE_PRAISE_ENABLED=false

# --- 自动回复开关 ---
# 开启后 Bot 会在群内发送"签到成功"等确认消息（默认 false，减少噪音）
FEISHU_AUTO_REPLY_ENABLED=false

# Feishu bootstrap inputs
FEISHU_TEST_CAMP_ID=
FEISHU_TEST_CHAT_ID=
FEISHU_TEST_CHAT_NAME=AI Seed Evaluator Test Group
FEISHU_TEST_CHAT_OWNER_OPEN_ID=
FEISHU_TEST_CHAT_MEMBER_OPEN_IDS=
FEISHU_BASE_NAME=AI Seed Evaluator Base

# Provider-neutral LLM contract for phase one
LLM_ENABLED=true
LLM_PROVIDER=glm
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=
# Sub4 盲评结论: glm-4.7 准确率100%+稳定性83%, 推荐生产使用
# 备选免费方案: glm-4.7-flash (准确率100%但受速率限制)
LLM_TEXT_MODEL=glm-4.7
# H2 多模态评分 (学员截图): glm-4.6v 付费版, glm-4.6v-flash 免费版(高峰期可能429)
LLM_VISION_MODEL=glm-4.6v
LLM_FILE_MODEL=
LLM_FILE_EXTRACTOR=glm_file_parser
LLM_FILE_PARSER_TOOL_TYPE=lite
LLM_TIMEOUT_MS=60000
LLM_MAX_INPUT_CHARS=6000

# --- LLM Worker (sub-project 1 Phase E) ---

# Maximum concurrent LLM scoring requests (default 3)
LLM_CONCURRENCY=3

# Maximum requests per second across the whole worker (default 5)
LLM_RATE_LIMIT_PER_SEC=5

# Worker poll interval in ms when the queue is empty (default 1500)
LLM_POLL_INTERVAL_MS=1500

# Per-task timeout in ms before retry (default 30000)
LLM_TASK_TIMEOUT_MS=30000

# Total attempts per task before surrendering to review_required (default 3)
LLM_MAX_ATTEMPTS=3

# --- Bootstrap Operators ---

# Comma-separated list of Feishu open ids to auto-promote to operator at seed time
BOOTSTRAP_OPERATOR_OPEN_IDS=

# Comma-separated list of admin open ids (excluded from student sync)
ADMIN_OPEN_IDS=
