# Local runtime
PORT=3000
APP_ENV=development
DATABASE_URL=./data/app.db

# Feishu app credentials. Leave blank until you connect a real app.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Event mode:
# - disabled: local-only, no Feishu inbound connection
# - webhook: Feishu pushes events to HTTP endpoints
# - long_connection: Feishu WS long connection for the real integration
FEISHU_EVENT_MODE=disabled
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Bot target used by /api/feishu/send-test and /api/announcements/run.
FEISHU_BOT_CHAT_ID=
FEISHU_BOT_RECEIVE_ID_TYPE=chat_id

# Base sync. Enable only after creating the Feishu Base app and tables.
FEISHU_BASE_ENABLED=false
FEISHU_BASE_APP_TOKEN=
FEISHU_BASE_MEMBERS_TABLE=
FEISHU_BASE_RAW_EVENTS_TABLE=
FEISHU_BASE_SCORES_TABLE=
FEISHU_BASE_WARNINGS_TABLE=
FEISHU_BASE_SNAPSHOTS_TABLE=

# Bootstrap inputs for npm run bootstrap:feishu.
FEISHU_TEST_CAMP_ID=
FEISHU_TEST_CHAT_ID=
FEISHU_TEST_CHAT_NAME=Pfizer HBU AI Evaluator Test Group
FEISHU_TEST_CHAT_OWNER_OPEN_ID=
FEISHU_TEST_CHAT_MEMBER_OPEN_IDS=
FEISHU_BASE_NAME=Pfizer HBU AI Evaluator Base

# Optional LLM config.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
